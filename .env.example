# Copie este arquivo para .env e preencha os valores.
# O arquivo .env NÃO deve ser versionado (está no .gitignore).

# Chave secreta do Django (gere uma própria em produção)
# SECRET_KEY=troque-esta-chave

# Debug (True em desenvolvimento, False em produção)
DEBUG=True

# Hosts permitidos, separados por vírgula.
# Para testar pelo celular, adicione o IP do PC na rede local.
ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# OCR / IA
# ---------------------------------------------------------------------------
# Backend de leitura do ICCID: "gemini", "openai" ou "mock"
OCR_BACKEND=gemini

# Credencial do Google Gemini (obrigatória quando OCR_BACKEND=gemini)
# Gere gratuitamente em https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.0-flash

# Credencial da OpenAI (obrigatória quando OCR_BACKEND=openai)
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# Câmera IP (captura de chips por estação fixa)
# ---------------------------------------------------------------------------
# Câmera Hikvision/OEM: o snapshot é buscado pelo servidor via HTTP (auth Digest)
# no endpoint ISAPI. Preencha usuário/senha da câmera.
CAMERA_IP=10.0.0.87
CAMERA_USER=admin
CAMERA_PASSWORD=
# Opcional: URL completa de snapshot (sobrescreve o padrão ISAPI montado pelo IP).
# Ex.: http://10.0.0.87/ISAPI/Streaming/channels/101/picture
CAMERA_SNAPSHOT_URL=
CAMERA_TIMEOUT=8

# ---------------------------------------------------------------------------
# Supabase Storage (imagens dos chips)
# ---------------------------------------------------------------------------
# Crie um bucket Public (ex.: chipcut-imagens) no painel do Supabase antes de
# usar. Use a SERVICE ROLE key (tem permissão de escrita) — nunca a anon key.
# Sem essas variáveis a captura funciona, mas as imagens não são salvas.
SUPABASE_URL=https://<projeto>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=chipcut-imagens

# Arquivar a FOTO do chip? Padrão False: a imagem serve só para o OCR e é
# descartada (apenas o ICCID/infos vão ao banco). True => envia ao Supabase.
CHIP_SALVAR_IMAGEM=False
